# KernelCI Status Monitoring Daemon configuration
# Default path: /etc/kernelci-status.toml
# All values shown below are the built-in defaults.

[server]
port = 2001

[database]
# Parent directory will be created automatically if it does not exist.
path = "/var/lib/kernelci-status/status.db"

[credentials]
# Default user created on first startup when no users exist in the database.
# Remove or comment out this section after initial setup.
username = "admin"
password = "changeme"

# Optional: ACME (Let's Encrypt) TLS with automatic renewal.
# When enabled, the plain [server].port above is ignored and the daemon
# listens on http_port (redirects everything to HTTPS) and https_port.
# Certificates are cached on disk and auto-renewed ~30 days before expiry.
# [acme]
# enabled = true
# domains = ["status.kernelci.org"]
# contact = "bot@kernelci.org"           # recommended: LE sends renewal reminders here
# cache_dir = "/var/lib/kernelci-status/acme"
# staging = true                         # default: use Let's Encrypt staging (untrusted certs
#                                        # but no rate limits). Flip to false for production.
# http_port = 80
# https_port = 443
